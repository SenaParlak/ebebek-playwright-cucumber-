{
  "name": "ebebek-playwright-cucumber",
  "version": "1.0.0",
  "description": "E-bebek Playwright Cucumber automation case study",
  "type": "module",
  "scripts": {
    "test": "cucumber-js \"features/**/*.feature\" --import \"src/support/**/*.js\" --import \"src/steps/**/*.js\"",
    "test:headed": "cross-env HEADLESS=false cucumber-js \"features/**/*.feature\" --import \"src/support/**/*.js\" --import \"src/steps/**/*.js\"",
    "test:parallel": "cucumber-js \"features/**/*.feature\" --import \"src/support/**/*.js\" --import \"src/steps/**/*.js\" --parallel 2",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "report": "npm run allure:generate && npm run allure:open"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^13.1.0",
    "@playwright/test": "^1.61.1",
    "allure-commandline": "^2.43.0",
    "allure-cucumberjs": "^3.10.2",
    "cross-env": "^10.0.0",
    "dotenv": "^17.4.2",
    "playwright": "^1.61.1"
  }
}